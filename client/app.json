{
  "expo": {
    "name": "Poker Monkey",
    "slug": "poker-monkey",
    "version": "1.0.0",
    "scheme": [
      "poker-monkey",
      "com.googleusercontent.apps.1056319941649-see3orn4pr726lj32s8leecpn98sidpf"
    ],
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "hu.poker.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8b891cf4-46a6-46b7-951b-7cc826e8a4e7"
      }
    },
    "plugins": [
      "expo-web-browser",
      "./plugins/withNoRequiredFeatures",
      "expo-audio",
      [
        "@sentry/react-native",
        {
          "autoUploadNativeSymbols": false,
          "autoUploadProguardMapping": false
        }
      ]
    ]
  }
}
